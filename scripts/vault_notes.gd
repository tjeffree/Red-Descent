extends RefCounted
## Red Descent — Vault note phrases
##
## The plinthed clipboards scattered through the Ruins' vault rooms each carry one
## of these: obscure English idioms, enshrined like recovered scripture. Read as
## artefacts by whoever digs this far, they read as a lost civilisation's stab at
## why it ever bothered — half profound, half nonsense, which is the joke. No place
## names (the heirs who find them could never locate the places anyway).
##
## main.gd shuffles this pool per dive and ties one phrase to each clipboard, so a
## given vault says something different every session.

const PHRASES: Array[String] = [
	"Make hay while the sun shines.",
	"Many a mickle makes a muckle.",
	"Needs must when the devil drives.",
	"Faint heart never won fair maid.",
	"All my eye and Betty Martin.",
	"A storm in a teacup — but oh, what a storm.",
	"The curate's egg: good in parts.",
	"Cold enough to freeze the balls off a brass monkey.",
	"He who sups with the devil should bring a long spoon.",
	"Might as well be hanged for a sheep as a lamb.",
	"Cut your coat according to your cloth.",
	"A rolling stone gathers no moss.",
	"Whistle down the wind.",
	"Still waters run deep.",
	"Don't teach your grandmother to suck eggs.",
	"Where there's muck there's brass.",
	"A nod is as good as a wink to a blind horse.",
	"The proof of the pudding is in the eating.",
]
